{
  "$schema": "https://json.schemastore.org/claude-code-settings.json",
  "permissions": {
    "allow": [
      "Bash",
      "Edit(*)",
      "Glob(*)",
      "Grep(*)",
      "LS(*)",
      "MultiEdit(*)",
      "Read(*)",
      "Task(*)",
      "TodoWrite(*)",
      "WebFetch",
      "WebSearch",
      "Write(*)",
      "mcp__mcp-router",
      "mcp__linear",
      "mcp__pagerduty",
      "mcp__prefect-docs",
      "mcp__prometheus-prd",
      "mcp__prometheus-dev",
      "mcp__prometheus-stg",
      "mcp__grafana",
      "mcp__terraform"
    ],
    "ask": [
      "Bash(rm:*)",
      "Bash(git push:*)"
    ]
  },
  "model": "opus[1m]",
  "enableAllProjectMcpServers": true,
  "enabledPlugins": {
    "prefect@prefect": true,
    "gopls-lsp@claude-plugins-official": true,
    "prefect-internal-skills@prefecthq-internal-skills": true
  },
  "extraKnownMarketplaces": {
    "prefecthq-internal-skills": {
      "source": {
        "source": "github",
        "repo": "prefecthq/internal-skills"
      }
    }
  },
  "spinnerTipsEnabled": false,
  "alwaysThinkingEnabled": false,
  "skipDangerousModePermissionPrompt": true,
  "feedbackSurveyState": {
    "lastShownTime": 1754598531219
  }
}
